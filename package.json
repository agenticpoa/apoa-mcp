{
  "name": "@apoa/mcp",
  "version": "0.1.3",
  "description": "APOA authorization for MCP servers \u2014 per-tool-call scoping, delegation chains, audit trails",
  "type": "module",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "apoa-mcp": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    },
    "./cli": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "gateway.config.example.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "authorization",
    "apoa",
    "policy",
    "agent",
    "delegation",
    "security",
    "audit"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/agenticpoa/apoa-mcp.git"
  },
  "homepage": "https://github.com/agenticpoa/apoa-mcp#readme",
  "dependencies": {
    "@apoa/core": "^0.2.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.0.0",
    "jose": "^6.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
